# LandSense AI - IoT + MCP Service
# Copy this file to .env and adjust values as needed.
# Defaults below run the service fully in Demo Mode with no hardware required.

# --- Mode switches ---
SENSOR_MODE=demo
RERA_MODE=mock

# --- Arduino / serial configuration (only used when SENSOR_MODE=live) ---
ARDUINO_PORT=/dev/ttyUSB0
ARDUINO_BAUD_RATE=9600
ARDUINO_READ_TIMEOUT_SECONDS=2.0

# --- Mock RERA dataset (only used when RERA_MODE=mock) ---
MOCK_RERA_DATA_PATH=data/mock_rera.json

# --- Live RERA configuration (only used when RERA_MODE=live) ---
LIVE_RERA_BASE_URL=
LIVE_RERA_API_KEY=

# --- OpenRouter AI configuration ---
# Set OPENROUTER_API_KEY to enable cloud VLM image reasoning in ai/engine.py
# and chat assistance in cloud/services/llm_service.py.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=openai/gpt-5.6-luna
OPENROUTER_MODEL=google/gemma-3-4b-it:free
OPENROUTER_APP_TITLE=LandSense
OPENROUTER_HTTP_REFERER=

# --- Logging ---
LOG_LEVEL=INFO
